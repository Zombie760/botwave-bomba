{
  "name": "botwavebomba",
  "version": "5.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "bun run scripts/dev_server.ts",
    "build": "bun run scripts/build_homepage.ts",
    "pipeline": "bun run scripts/run_pipeline.ts",
    "minify:css": "bun build assets/css/base.css assets/css/tokens.css assets/css/feed.css assets/css/theme.css --outdir=assets/css/min --minify",
    "minify:js": "bun build assets/js/theme.js assets/js/api-adapter.js assets/js/feed.js --outdir=assets/js/min --minify",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "validate": "bun run build && bun run minify:css && bun run minify:js",
    "prepublishOnly": "bun run validate"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "jsdom": "^29.1.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/jsdom": "^28.0.3"
  }
}